# ============================================
# 환경변수 템플릿 파일
# ============================================
# 사용법:
# 1. 이 파일을 .env.local로 복사하세요
# 2. 실제 값으로 채워넣으세요
# 3. .env.local은 Git에 절대 커밋하지 마세요!
# ============================================

# JWT Secret (Base64 인코딩된 32바이트 이상의 키)
# 생성 방법: openssl rand -base64 32
JWT_SECRET=

# OAuth2 Client IDs & Secrets
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
APPLE_CLIENT_ID=com.nugulmap.native

# Apple authorization code 교환과 계정 삭제 revoke 설정(운영 필수).
# APPLE_PRIVATE_KEY_BASE64: Apple .p8 파일 자체를 base64로 인코딩한 값
#   생성 예: base64 < AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
# APPLE_TOKEN_ENCRYPTION_KEY: refresh token 저장용 AES-256 키
#   생성 예: openssl rand -base64 32
APPLE_REVOCATION_ENABLED=true
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_BASE64=
APPLE_TOKEN_ENCRYPTION_KEY=

# App Store Guideline 1.2 신고 문의 채널.
# nugulmap.com 메일 수신(MX)이 준비되기 전에는 비워두고 공개 지원 요청 API를 사용합니다.
MODERATION_CONTACT_EMAIL=
# 운영자 지원 요청 조회용 긴 무작위 비밀값 (운영 환경 필수)
# 생성 예: openssl rand -base64 48
MODERATION_OPERATOR_KEY=
# 로컬·비운영 환경용 값입니다. 운영(prod)은 개인정보 안내와 일치하도록 30일/UTC 03:30으로 고정합니다.
SUPPORT_REQUEST_RETENTION_DAYS=30
SUPPORT_REQUEST_PURGE_CRON=0 30 3 * * *

# 운영 네이티브 OAuth는 PKCE code 교환만 허용하고 토큰 딥링크를 차단합니다.
APP_OAUTH_MOBILE_CODE_REQUIRED=true

# OAuth2 Redirect URLs
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:3000
OAUTH2_FAILURE_REDIRECT_URL=http://localhost:3000/login?error=oauth_failed

# Cookie Security Settings
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax

# CORS Settings
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# MinIO 운영 관리자 계정. 앱 런타임 키와 반드시 다른 값으로 설정합니다.
# 관리자 계정은 버킷/정책 초기화에만 쓰이며 API 서버에는 전달하지 않습니다.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# AWS S3 또는 MinIO 앱 런타임 계정
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# Season 3 live crowd and popup insights
# 키가 없거나 검증된 최신 관측값이 없으면 places=[] / NO_VERIFIED_DATA를 반환합니다.
# --require-live requires one live crowd source:
#   1) SEOUL_CITYDATA_API_KEY, or
#   2) TELECOM_CROWD_API_KEY + TELECOM_CROWD_URL_TEMPLATE
# and one public event source:
#   1) KTO_TOUR_API_KEY, or
#   2) SEOUL_CULTURE_API_KEY for runtime Seoul culture API lookup, or
#   3) public event API records collected in POPUP_TRENDS_FILE.
# 서울특별시 실시간 도시데이터 인증키
SEOUL_CITYDATA_API_KEY=
# 통신사/상용 장소 혼잡도 API 어댑터(선택): URL 템플릿은 {placeId}, {placeName}, {seoulAreaCode}, {seoulAreaName}, {lat}, {lng}, {apiKey} 사용 가능
# 키를 URL 쿼리로만 보내는 API는 TELECOM_CROWD_API_KEY_HEADER=none 으로 설정하세요.
TELECOM_CROWD_API_KEY=
TELECOM_CROWD_URL_TEMPLATE=
TELECOM_CROWD_API_KEY_HEADER=appKey
# 한국관광공사 TourAPI 서비스키
KTO_TOUR_API_KEY=
# 서울문화포털 문화행사 OpenAPI 키. API 서버 런타임 조회와 popup/event collector가 함께 사용합니다.
# 비어 있으면 해당 출처를 건너뜁니다. sample 데이터는 운영 수집에 사용하지 않습니다.
SEOUL_CULTURE_API_KEY=
SEOUL_CULTURE_API_BASE_URL=http://openapi.seoul.go.kr:8088
SEOUL_CULTURE_API_PAGE_SIZE=1000
SEOUL_CULTURE_API_MAX_PAGES=25
# backend/data-scripts/scripts/collect_popup_trends.py 산출물 경로
POPUP_TRENDS_FILE=../data-scripts/data/popup-trends.json
# Docker popup/event trend collector refresh settings
# 프로세스는 5분마다 깨어나며 실제 요청은 출처별 주기(4~24시간)를 따릅니다.
POPUP_TRENDS_REFRESH_SECONDS=300
POPUP_TRENDS_TIMEOUT_SECONDS=10
POPUP_TRENDS_MIN_RECORDS=3
# 이 시간을 넘긴 수집 파일은 STALE이며 live-ready로 판정하지 않습니다.
POPUP_TRENDS_MAX_AGE_HOURS=24
# 외부 인사이트 API 캐시 TTL(초)
INSIGHTS_CACHE_TTL_SECONDS=300
# 행사/팝업 snapshot은 다음 일일 refresh까지 유지합니다.
INSIGHTS_EVENT_CACHE_TTL_SECONDS=86400
# 외부 혼잡도는 요청 스레드가 아니라 background warm-up에서만 조회합니다.
INSIGHTS_HOTPLACE_WARMUP_ENABLED=true
INSIGHTS_HOTPLACE_WARMUP_INITIAL_DELAY_MS=0
INSIGHTS_HOTPLACE_WARMUP_INTERVAL_MS=300000
INSIGHTS_HOTPLACE_WARMUP_MAX_CONCURRENCY=4
# 서울시 문화행사 원천은 일 1회 갱신되므로 API 전체 페이지 refresh도 24시간 주기를 사용합니다.
INSIGHTS_EVENT_WARMUP_ENABLED=true
INSIGHTS_EVENT_WARMUP_INITIAL_DELAY_MS=0
INSIGHTS_EVENT_WARMUP_INTERVAL_MS=86400000
# 장소별 실패 negative cache와 연속 전송 실패 circuit cooldown
INSIGHTS_PROVIDER_FAILURE_COOLDOWN_SECONDS=60
INSIGHTS_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
# 공급자 관측값 신선도: 10분 이내 CURRENT, 30분 이내 DELAYED, 이후 STALE/fallback
INSIGHTS_CROWD_CURRENT_MAX_AGE_MINUTES=10
INSIGHTS_CROWD_LIVE_MAX_AGE_MINUTES=30
# 관측시각이 없는 공급자 응답을 운영에서 허용하지 않는 것이 기본입니다.
INSIGHTS_CROWD_ALLOW_MISSING_OBSERVATION_TIME=false
# 공개 지도 인사이트 API의 인스턴스별 보수적 rate limit
APP_INSIGHTS_RATE_LIMIT_REQUESTS_PER_WINDOW=120
APP_INSIGHTS_RATE_LIMIT_WINDOW_SECONDS=60
APP_INSIGHTS_RATE_LIMIT_MAX_TRACKED_CLIENTS=10000
APP_SECURITY_SENSITIVE_RATE_LIMIT_ENABLED=true
APP_SECURITY_SENSITIVE_RATE_LIMIT_REQUESTS_PER_WINDOW=30
APP_SECURITY_SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=60
APP_SECURITY_SENSITIVE_RATE_LIMIT_MAX_TRACKED_CLIENTS=10000
# Database (프로덕션용, 개발환경은 H2 사용)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=
# MySQL 운영 관리자 비밀번호. 앱 비밀번호와 반드시 다른 값으로 설정합니다.
# root는 백업/마이그레이션에만 쓰며 API 서버에는 전달하지 않습니다.
MYSQL_ROOT_PASSWORD=
MYSQL_USERNAME=
# 16자 이상 URL/base64-safe 문자열만 사용합니다. 예: openssl rand -base64 32 | tr -d '\n'
MYSQL_PASSWORD=

# Spring Profile
# SPRING_PROFILES_ACTIVE=dev
