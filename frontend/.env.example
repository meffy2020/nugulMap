# Local frontend defaults.
#
# For Season 2 mock-live verification, run the backend with:
#   MOCK_CROWD=1 REQUIRE_LIVE=1 backend/api-server/scripts/run-season2-local.sh
# Then point the web client at the local API:
#   NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:18080
#
# For production builds, use:
#   NEXT_PUBLIC_API_BASE_URL=https://api.nugulmap.com

NEXT_PUBLIC_KAKAOMAP_APIKEY=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:18080
